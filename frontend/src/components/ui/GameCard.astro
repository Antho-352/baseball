---
/**
 * GameCard Component - Design System compliant
 *
 * Score card pour afficher un match (live, final, scheduled)
 * Suit les specs du DESIGN-SYSTEM.md
 *
 * Props:
 * - homeTeam: Nom équipe domicile
 * - awayTeam: Nom équipe extérieur
 * - homeScore?: Score domicile
 * - awayScore?: Score extérieur
 * - status: Statut du match
 * - startTime?: Date/heure du match
 * - gameId: ID du match (pour le lien)
 * - league?: Ligue (MLB/KBO/NPB)
 * - inning?: Manche en cours (si live)
 * - homeRecord?: Record équipe domicile (ex: "35-22")
 * - awayRecord?: Record équipe extérieur
 * - homeRank?: Classement division domicile
 * - awayRank?: Classement division extérieur
 * - variant?: 'default' | 'featured'
 */

interface Props {
  homeTeam: string;
  awayTeam: string;
  homeScore?: number | null;
  awayScore?: number | null;
  status: 'live' | 'final' | 'scheduled' | 'postponed';
  startTime?: Date | string;
  gameId: string;
  league?: string;
  inning?: string;
  homeRecord?: string;
  awayRecord?: string;
  homeRank?: string;
  awayRank?: string;
  variant?: 'default' | 'featured';
  class?: string;
}

const {
  homeTeam,
  awayTeam,
  homeScore,
  awayScore,
  status,
  startTime,
  gameId,
  league = 'MLB',
  inning,
  homeRecord,
  awayRecord,
  homeRank,
  awayRank,
  variant = 'default',
  class: className = '',
} = Astro.props;

// Format time
let timeString = '';
if (startTime) {
  const date = typeof startTime === 'string' ? new Date(startTime) : startTime;
  timeString = date.toLocaleTimeString('fr-FR', {
    hour: '2-digit',
    minute: '2-digit',
    timeZone: 'Europe/Paris'
  });
}

// Determine leading team
const homeLeading = homeScore !== null && awayScore !== null && homeScore > awayScore;
const awayLeading = homeScore !== null && awayScore !== null && awayScore > homeScore;

// Get team abbreviations (first 3 chars uppercase)
const homeAbbrev = homeTeam.substring(0, 3).toUpperCase();
const awayAbbrev = awayTeam.substring(0, 3).toUpperCase();

// League colors for logos
const leagueColors: Record<string, string> = {
  'MLB': '#e8102e',
  'KBO': '#0052a5',
  'NPB': '#e67e00',
};
---

<div class={`score-card ${className}`}>
  <!-- Header: League + Status Badge -->
  <div class="score-card-header">
    <span class="score-card-league">{league.toUpperCase()}</span>

    {status === 'live' && (
      <span class="badge-live">
        <div class="ticker-dot"></div>
        {inning || 'En direct'}
      </span>
    )}

    {status === 'final' && (
      <span class="badge-final">Terminé</span>
    )}

    {status === 'scheduled' && timeString && (
      <span class="badge-scheduled">{timeString}</span>
    )}

    {status === 'postponed' && (
      <span class="badge-postponed">Reporté</span>
    )}
  </div>

  <!-- Body: Teams + Scores -->
  <div class="score-card-body">
    <!-- Away team -->
    <div class="score-row">
      <div class="score-team-logo" style={`background: ${leagueColors[league] || '#1e40af'}`}>
        {awayAbbrev}
      </div>
      <div class="score-team-info">
        <div class="score-team-name">{awayTeam}</div>
        {awayRecord && (
          <div class="score-team-record">
            {awayRecord}{awayRank && ` • ${awayRank}`}
          </div>
        )}
      </div>
      {awayScore !== null ? (
        <div class={`score-num ${awayLeading ? 'leading' : ''}`}>
          {awayScore}
        </div>
      ) : (
        <div class="score-num score-num-empty">—</div>
      )}
    </div>

    <!-- Home team -->
    <div class="score-row">
      <div class="score-team-logo" style={`background: ${leagueColors[league] || '#1e40af'}`}>
        {homeAbbrev}
      </div>
      <div class="score-team-info">
        <div class="score-team-name">{homeTeam}</div>
        {homeRecord && (
          <div class="score-team-record">
            {homeRecord}{homeRank && ` • ${homeRank}`}
          </div>
        )}
      </div>
      {homeScore !== null ? (
        <div class={`score-num ${homeLeading ? 'leading' : ''}`}>
          {homeScore}
        </div>
      ) : (
        <div class="score-num score-num-empty">—</div>
      )}
    </div>
  </div>

  <!-- Footer: Link to details -->
  <div class="score-card-footer">
    <a class="score-link" href={`/match/${gameId}/`}>
      Détails du match →
    </a>
  </div>
</div>

<style>
  .score-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-base);
  }

  .score-card:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-md);
  }

  /* Header */
  .score-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-3) var(--space-4);
    background-color: var(--color-surface-2);
    border-bottom: 1px solid var(--color-border);
  }

  .score-card-league {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  /* Badges */
  .badge-live,
  .badge-final,
  .badge-scheduled,
  .badge-postponed {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 2px 8px;
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-radius: var(--radius-full);
  }

  .badge-live {
    background: rgba(232, 16, 46, 0.12);
    color: var(--color-red);
  }

  .badge-final {
    background: rgba(255, 255, 255, 0.05);
    color: var(--color-text-muted);
  }

  .badge-scheduled {
    background: rgba(245, 158, 11, 0.12);
    color: var(--color-gold);
  }

  .badge-postponed {
    background: rgba(255, 255, 255, 0.05);
    color: var(--color-text-muted);
  }

  .ticker-dot {
    width: 6px;
    height: 6px;
    background-color: var(--color-red);
    border-radius: 50%;
    animation: pulse 1.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* Body */
  .score-card-body {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .score-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .score-team-logo {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 800;
    color: white;
    flex-shrink: 0;
  }

  .score-team-info {
    flex: 1;
    min-width: 0;
  }

  .score-team-name {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--color-text);
  }

  .score-team-record {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: 2px;
  }

  .score-num {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
    min-width: 32px;
    text-align: right;
  }

  .score-num.leading {
    color: var(--color-text);
  }

  .score-num-empty {
    font-size: var(--text-base);
  }

  /* Footer */
  .score-card-footer {
    padding: var(--space-3) var(--space-4);
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: flex-end;
  }

  .score-link {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .score-link:hover {
    color: var(--color-red);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .score-team-name {
      font-size: var(--text-xs);
    }

    .score-num {
      font-size: 1.25rem;
    }
  }
</style>
