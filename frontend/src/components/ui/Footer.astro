---
/**
 * Footer Component - Design System compliant
 *
 * Footer avec mentions ANJ obligatoires
 */

const currentYear = new Date().getFullYear();

const footerColumns = [
  {
    title: 'MLB',
    links: [
      { name: 'Équipes', href: '/mlb/equipes/' },
      { name: 'Joueurs', href: '/mlb/joueurs/' },
      { name: 'Scores', href: '/mlb/scores/' },
      { name: 'Classement', href: '/mlb/classement/' },
      { name: 'Stats', href: '/mlb/stats/' },
    ],
  },
  {
    title: 'KBO',
    links: [
      { name: 'Équipes', href: '/kbo/equipes/' },
      { name: 'Joueurs', href: '/kbo/joueurs/' },
      { name: 'Scores', href: '/kbo/scores/' },
      { name: 'Classement', href: '/kbo/classement/' },
    ],
  },
  {
    title: 'NPB',
    links: [
      { name: 'Équipes', href: '/npb/equipes/' },
      { name: 'Joueurs', href: '/npb/joueurs/' },
      { name: 'Scores', href: '/npb/scores/' },
      { name: 'Classement', href: '/npb/classement/' },
    ],
  },
  {
    title: 'Infos',
    links: [
      { name: 'Pronostics', href: '/pronostics/' },
      { name: 'News', href: '/news/' },
      { name: 'Histoire', href: '/histoire/' },
      { name: 'À propos', href: '/a-propos/' },
      { name: 'Contact', href: '/contact/' },
    ],
  },
];
---

<footer>
  <div class="container">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <div class="logo">
          <span class="logo-icon">⚾</span>
          <span class="logo-text">home-run<span>.fr</span></span>
        </div>
        <p>
          La référence française du baseball professionnel. MLB, KBO et NPB couverts en temps réel.
        </p>
      </div>

      <!-- Navigation columns -->
      {footerColumns.map((column) => (
        <div>
          <div class="footer-col-title">{column.title}</div>
          <ul class="footer-links">
            {column.links.map((link) => (
              <li><a href={link.href}>{link.name}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="footer-bottom">
      <!-- Mentions légales ANJ (OBLIGATOIRE) -->
      <p class="footer-legal">
        home-run.fr est un site d'information sur le baseball professionnel.
        Les pronostics publiés sont à titre indicatif et ne constituent en aucun cas une incitation au jeu.
        Jouer comporte des risques : endettement, dépendance... Appelez le 09 74 75 13 13 (appel non surtaxé).
        <strong>18+</strong>. Les jeux d'argent sont interdits aux mineurs.
        Tous les opérateurs d'affiliation présentés sur ce site sont agréés par l'ANJ.
        <a href="https://www.jeu-responsable.fr" target="_blank" rel="noopener noreferrer" style="color:var(--color-red)">
          jeu-responsable.fr
        </a>
      </p>

      <div class="footer-meta">
        © {currentYear} home-run.fr • Tous droits réservés •
        <a href="/mentions-legales/">Mentions légales</a> •
        <a href="/confidentialite/">Confidentialité</a>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    background-color: var(--color-surface);
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-20);
    padding: var(--space-16) 0 var(--space-8);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-12);
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Brand */
  .footer-brand {
    padding-right: var(--space-4);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .logo-icon {
    font-size: var(--text-2xl);
  }

  .logo-text {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--font-extrabold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text);
  }

  .logo-text span {
    color: var(--color-red);
  }

  .footer-brand p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  /* Columns */
  .footer-col-title {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: var(--space-2);
  }

  .footer-links a {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .footer-links a:hover {
    color: var(--color-red);
  }

  /* Bottom */
  .footer-bottom {
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .footer-legal {
    font-size: 10px;
    color: var(--color-text-faint);
    line-height: 1.6;
    max-width: 80ch;
    margin-bottom: var(--space-4);
  }

  .footer-legal a {
    text-decoration: underline;
    transition: opacity var(--transition-base);
  }

  .footer-legal a:hover {
    opacity: 0.8;
  }

  .footer-meta {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .footer-meta a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .footer-meta a:hover {
    color: var(--color-red);
  }
</style>
