---
/**
 * Footer Component
 *
 * Footer du site avec liens, mentions légales ANJ, etc.
 *
 * Props: Aucune (contenu statique)
 *
 * Usage:
 * <Footer />
 */

const currentYear = new Date().getFullYear();

// Navigation sections
const footerSections = [
  {
    title: 'Ligues',
    links: [
      { name: 'MLB', href: '/mlb/' },
      { name: 'KBO', href: '/kbo/' },
      { name: 'NPB', href: '/npb/' },
      { name: 'Calendrier complet', href: '/calendrier/' },
    ],
  },
  {
    title: 'Contenu',
    links: [
      { name: 'Pronostics', href: '/pronostics/' },
      { name: 'News', href: '/news/' },
      { name: 'Statistiques', href: '/stats/' },
      { name: 'Histoire du baseball', href: '/histoire/' },
    ],
  },
  {
    title: 'Site',
    links: [
      { name: 'À propos', href: '/a-propos/' },
      { name: 'Contact', href: '/contact/' },
      { name: 'Mentions légales', href: '/mentions-legales/' },
      { name: 'Politique de confidentialité', href: '/confidentialite/' },
    ],
  },
];
---

<footer class="bg-bg-surface border-t border-border mt-16">
  <div class="container mx-auto py-12">
    <!-- Footer grid -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
      <!-- Brand section -->
      <div>
        <a href="/" class="flex items-center gap-2 font-bold text-xl mb-4">
          <span class="text-2xl">⚾</span>
          <span>home-run.fr</span>
        </a>
        <p class="text-sm text-text-muted mb-4">
          Votre référence baseball en français. Scores, statistiques et pronostics pour la MLB, KBO et NPB.
        </p>
        <!-- Social links (placeholder) -->
        <div class="flex gap-3">
          <a
            href="#"
            class="text-text-muted hover:text-primary transition-colors"
            aria-label="Twitter"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84" />
            </svg>
          </a>
          <a
            href="#"
            class="text-text-muted hover:text-primary transition-colors"
            aria-label="Facebook"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation columns -->
      {footerSections.map((section) => (
        <div>
          <h3 class="font-semibold mb-4">{section.title}</h3>
          <ul class="space-y-2">
            {section.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-text-muted hover:text-primary transition-colors"
                >
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- ANJ Warning (Jeu responsable) -->
    <div class="border-t border-border pt-8 mb-6">
      <div class="bg-warning-bg border-l-4 border-warning p-4 rounded">
        <p class="text-sm text-warning-light font-semibold mb-2">
          ⚠️ Jeu Responsable
        </p>
        <p class="text-xs text-text-muted leading-relaxed">
          <strong>18+</strong> | Les jeux d'argent sont interdits aux mineurs.
          Jouer comporte des risques : endettement, dépendance...
          Appelez le <strong>09 74 75 13 13</strong> (appel non surtaxé) ou consultez
          <a href="https://www.joueurs-info-service.fr/" target="_blank" rel="noopener noreferrer" class="underline hover:text-primary">
            joueurs-info-service.fr
          </a>
        </p>
      </div>
    </div>

    <!-- Copyright -->
    <div class="border-t border-border pt-6 text-center text-sm text-text-muted">
      <p>
        © {currentYear} home-run.fr - Tous droits réservés
      </p>
      <p class="mt-2">
        Made with ⚾ for baseball fans
      </p>
    </div>
  </div>
</footer>
