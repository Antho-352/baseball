---
/**
 * BettingStrip Component
 *
 * Displays ANJ-approved bookmaker links with legal warnings
 * MUST comply with French gambling regulations
 */

export interface Bookmaker {
  name: string;
  logo?: string;
  affiliateUrl: string;
  bonus?: string;
}

interface Props {
  bookmakers: Bookmaker[];
  variant?: 'horizontal' | 'compact';
}

const {
  bookmakers,
  variant = 'horizontal'
} = Astro.props;

// Only show ANJ-approved operators
const anjApprovedOperators = [
  'Betclic',
  'Unibet',
  'Winamax',
  'PMU',
  'ParionsSport'
];

const filteredBookmakers = bookmakers.filter(b =>
  anjApprovedOperators.some(approved =>
    b.name.toLowerCase().includes(approved.toLowerCase())
  )
);
---

<aside class={`betting-strip betting-strip--${variant}`}>
  <div class="container">
    <!-- ANJ Legal Warning (MANDATORY) -->
    <div class="betting-warning">
      <svg
        class="warning-icon"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="2"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"
        />
      </svg>

      <div class="warning-content">
        <p class="warning-text">
          <strong>Jeu responsable :</strong> Jouer comporte des risques : endettement, dépendance...
        </p>
        <p class="warning-help">
          Pour obtenir de l'aide :
          <a href="https://www.joueurs-info-service.fr/" target="_blank" rel="noopener noreferrer">
            joueurs-info-service.fr
          </a>
          |
          <a href="tel:0974751313">09 74 75 13 13</a>
          (appel non surtaxé)
        </p>
      </div>
    </div>

    <!-- Bookmakers list -->
    {filteredBookmakers.length > 0 && (
      <div class="betting-bookmakers">
        <span class="bookmakers-label">Paris sportifs agréés ANJ :</span>

        <div class="bookmakers-list">
          {filteredBookmakers.map((bookmaker) => (
            <a
              href={bookmaker.affiliateUrl}
              target="_blank"
              rel="noopener noreferrer sponsored"
              class="bookmaker-link"
            >
              {bookmaker.logo ? (
                <img
                  src={bookmaker.logo}
                  alt={bookmaker.name}
                  class="bookmaker-logo"
                  loading="lazy"
                />
              ) : (
                <span class="bookmaker-name">{bookmaker.name}</span>
              )}

              {bookmaker.bonus && (
                <span class="bookmaker-bonus">{bookmaker.bonus}</span>
              )}
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- 18+ Legal requirement -->
    <div class="betting-legal">
      <span class="legal-badge">18+</span>
      <span class="legal-text">
        Les jeux d'argent sont interdits aux mineurs
      </span>
    </div>
  </div>
</aside>

<style>
  .betting-strip {
    background-color: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-6) 0;
  }

  .betting-strip--compact {
    padding: var(--space-4) 0;
  }

  /* ANJ Warning (required by law) */
  .betting-warning {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-4);
    background-color: var(--color-warning-bg);
    border: 1px solid var(--color-warning);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-6);
  }

  [data-theme="dark"] .betting-warning {
    background-color: rgba(251, 191, 36, 0.1);
  }

  .warning-icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    color: var(--color-warning);
  }

  .warning-content {
    flex: 1;
  }

  .warning-text {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .warning-text strong {
    font-weight: var(--font-bold);
  }

  .warning-help {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .warning-help a {
    color: var(--color-primary);
    text-decoration: underline;
    font-weight: var(--font-semibold);
  }

  .warning-help a:hover {
    color: var(--color-primary-hover);
  }

  /* Bookmakers section */
  .betting-bookmakers {
    margin-bottom: var(--space-6);
  }

  .bookmakers-label {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .bookmakers-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .bookmaker-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4);
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
    text-decoration: none;
    min-width: 120px;
  }

  .bookmaker-link:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .bookmaker-logo {
    height: 32px;
    width: auto;
    max-width: 100px;
    object-fit: contain;
  }

  .bookmaker-name {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text);
  }

  .bookmaker-bonus {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    color: var(--color-success);
    text-align: center;
  }

  /* Legal requirement (18+) */
  .betting-legal {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3);
    background-color: var(--color-error-bg);
    border-radius: var(--radius-md);
  }

  [data-theme="dark"] .betting-legal {
    background-color: rgba(239, 68, 68, 0.1);
  }

  .legal-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: var(--font-extrabold);
    color: white;
    background-color: var(--color-error);
    border-radius: var(--radius-full);
  }

  .legal-text {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-error);
  }

  /* Compact variant adjustments */
  .betting-strip--compact .betting-warning {
    padding: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .betting-strip--compact .warning-icon {
    width: 20px;
    height: 20px;
  }

  .betting-strip--compact .bookmakers-list {
    gap: var(--space-3);
  }

  .betting-strip--compact .bookmaker-link {
    min-width: 100px;
    padding: var(--space-3);
  }

  /* Mobile adjustments */
  @media (max-width: 640px) {
    .betting-warning {
      flex-direction: column;
    }

    .bookmakers-list {
      justify-content: center;
    }

    .bookmaker-link {
      flex: 1;
      min-width: 0;
    }

    .betting-legal {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
