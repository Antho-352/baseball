---
/**
 * NewsGrid Component
 *
 * Grid layout for news articles with featured article
 * Matches mockup design with responsive 3-column grid
 */

export interface NewsArticle {
  id: string;
  title: string;
  excerpt: string;
  image?: string;
  category: string;
  league?: 'mlb' | 'kbo' | 'npb';
  publishedAt: string;
  slug: string;
  isFeatured?: boolean;
}

interface Props {
  articles: NewsArticle[];
  showFeatured?: boolean;
}

const { articles, showFeatured = true } = Astro.props;

// Separate featured article from others
const featured = showFeatured ? articles.find(a => a.isFeatured) || articles[0] : null;
const regular = featured ? articles.filter(a => a.id !== featured.id) : articles;

// Format date
const formatDate = (dateString: string) => {
  const date = new Date(dateString);
  return new Intl.DateTimeFormat('fr-FR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  }).format(date);
};

// Get league color
const getLeagueColor = (league?: string) => {
  switch (league) {
    case 'mlb': return 'var(--color-mlb)';
    case 'kbo': return 'var(--color-kbo)';
    case 'npb': return 'var(--color-npb)';
    default: return 'var(--color-primary)';
  }
};
---

<section class="news-grid-section">
  <div class="container">
    <!-- Section header -->
    <div class="section-header">
      <h2 class="section-title">Actualités</h2>
      <a href="/news/" class="section-link">
        Voir toutes les news
        <svg
          class="link-icon"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
          />
        </svg>
      </a>
    </div>

    <div class="news-grid">
      <!-- Featured article (if enabled) -->
      {featured && (
        <article class="news-article news-featured">
          <a href={`/news/${featured.slug}/`} class="article-link">
            {featured.image && (
              <div class="article-image">
                <img src={featured.image} alt={featured.title} loading="lazy" />
                <div class="article-overlay"></div>
              </div>
            )}

            <div class="article-content">
              <div class="article-meta">
                {featured.league && (
                  <span
                    class="article-league"
                    style={`background-color: ${getLeagueColor(featured.league)};`}
                  >
                    {featured.league.toUpperCase()}
                  </span>
                )}
                <span class="article-category">{featured.category}</span>
                <span class="article-date">{formatDate(featured.publishedAt)}</span>
              </div>

              <h3 class="article-title">{featured.title}</h3>
              <p class="article-excerpt">{featured.excerpt}</p>

              <span class="article-cta">
                Lire l'article
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
                  />
                </svg>
              </span>
            </div>
          </a>
        </article>
      )}

      <!-- Regular articles grid -->
      {regular.map((article) => (
        <article class="news-article">
          <a href={`/news/${article.slug}/`} class="article-link">
            {article.image && (
              <div class="article-image">
                <img src={article.image} alt={article.title} loading="lazy" />
              </div>
            )}

            <div class="article-content">
              <div class="article-meta">
                {article.league && (
                  <span
                    class="article-league"
                    style={`background-color: ${getLeagueColor(article.league)};`}
                  >
                    {article.league.toUpperCase()}
                  </span>
                )}
                <span class="article-category">{article.category}</span>
              </div>

              <h3 class="article-title">{article.title}</h3>
              <p class="article-excerpt">{article.excerpt}</p>

              <span class="article-date">{formatDate(article.publishedAt)}</span>
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .news-grid-section {
    padding: var(--space-16) 0;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-8);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: var(--font-extrabold);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .section-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    transition: color var(--transition-base);
  }

  .section-link:hover {
    color: var(--color-primary-hover);
  }

  .link-icon {
    width: 16px;
    height: 16px;
    transition: transform var(--transition-base);
  }

  .section-link:hover .link-icon {
    transform: translateX(4px);
  }

  .news-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .news-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .news-featured {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 1024px) {
    .news-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .news-featured {
      grid-column: 1 / 3;
      grid-row: 1 / 3;
    }
  }

  .news-article {
    position: relative;
    background-color: var(--color-surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-base);
    border: 1px solid var(--color-border);
  }

  .news-article:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .article-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .article-image {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background-color: var(--color-surface-hover);
  }

  .news-featured .article-image {
    aspect-ratio: 2 / 1;
  }

  .article-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .news-article:hover .article-image img {
    transform: scale(1.05);
  }

  .article-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.6) 0%,
      transparent 50%
    );
  }

  .article-content {
    padding: var(--space-5);
  }

  .news-featured .article-content {
    padding: var(--space-6);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
    flex-wrap: wrap;
  }

  .article-league {
    padding: var(--space-1) var(--space-2);
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius-sm);
    color: white;
  }

  .article-category {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .article-date {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .article-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: var(--leading-tight);
    margin-bottom: var(--space-3);
  }

  .news-featured .article-title {
    font-size: var(--text-2xl);
  }

  .article-excerpt {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-3);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .news-featured .article-excerpt {
    -webkit-line-clamp: 4;
  }

  .article-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
  }

  .article-cta svg {
    width: 16px;
    height: 16px;
    transition: transform var(--transition-base);
  }

  .news-article:hover .article-cta svg {
    transform: translateX(4px);
  }

  /* Mobile adjustments */
  @media (max-width: 640px) {
    .section-header {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-3);
    }
  }
</style>
