---
/**
 * Ticker Component
 *
 * Scrolling ticker bar displaying live scores and updates
 * Matches mockup design with smooth horizontal scrolling
 */

export interface TickerItem {
  id: string;
  league: 'mlb' | 'kbo' | 'npb';
  homeTeam: string;
  awayTeam: string;
  homeScore?: number;
  awayScore?: number;
  inning?: string;
  status: 'live' | 'final' | 'scheduled';
}

interface Props {
  items: TickerItem[];
  speed?: 'slow' | 'medium' | 'fast';
}

const { items, speed = 'medium' } = Astro.props;

// Animation duration based on speed
const speedMap = {
  slow: '60s',
  medium: '40s',
  fast: '25s'
};

const animationDuration = speedMap[speed];

// League color mapping
const getLeagueColor = (league: string) => {
  switch (league) {
    case 'mlb': return 'var(--color-mlb)';
    case 'kbo': return 'var(--color-kbo)';
    case 'npb': return 'var(--color-npb)';
    default: return 'var(--color-primary)';
  }
};
---

<div class="ticker-container">
  <div class="ticker-track" style={`--animation-duration: ${animationDuration};`}>
    <!-- Duplicate items for seamless loop -->
    {[...items, ...items].map((item) => (
      <div class="ticker-item">
        <span
          class="ticker-league"
          style={`background-color: ${getLeagueColor(item.league)};`}
        >
          {item.league.toUpperCase()}
        </span>

        <span class="ticker-teams">
          {item.awayTeam} vs {item.homeTeam}
        </span>

        {item.status === 'live' && (
          <span class="ticker-score ticker-live">
            {item.awayScore ?? 0}-{item.homeScore ?? 0}
            {item.inning && <span class="ticker-inning">{item.inning}</span>}
          </span>
        )}

        {item.status === 'final' && (
          <span class="ticker-score">
            F: {item.awayScore}-{item.homeScore}
          </span>
        )}

        {item.status === 'scheduled' && (
          <span class="ticker-scheduled">
            À venir
          </span>
        )}
      </div>
    ))}
  </div>
</div>

<style>
  .ticker-container {
    background-color: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
    position: relative;
    z-index: var(--z-sticky);
  }

  .ticker-track {
    display: flex;
    gap: var(--space-6);
    padding: var(--space-3) 0;
    animation: scroll-ticker var(--animation-duration) linear infinite;
    will-change: transform;
  }

  .ticker-track:hover {
    animation-play-state: paused;
  }

  .ticker-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    white-space: nowrap;
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .ticker-league {
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    color: white;
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
  }

  .ticker-teams {
    color: var(--color-text);
  }

  .ticker-score {
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }

  .ticker-live {
    color: var(--color-live);
    font-weight: var(--font-bold);
  }

  .ticker-inning {
    margin-left: var(--space-2);
    font-size: var(--text-xs);
    opacity: 0.8;
  }

  .ticker-scheduled {
    color: var(--color-text-muted);
    font-size: var(--text-xs);
  }

  @keyframes scroll-ticker {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* Pause animation on reduced motion preference */
  @media (prefers-reduced-motion: reduce) {
    .ticker-track {
      animation: none;
    }
  }

  /* Mobile adjustments */
  @media (max-width: 640px) {
    .ticker-item {
      font-size: var(--text-xs);
      gap: var(--space-2);
    }
  }
</style>
