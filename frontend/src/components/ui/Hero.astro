---
/**
 * Hero Component
 *
 * Homepage hero section with featured game and CTA
 * Two-column layout: left (text + CTA), right (featured game card)
 */

import GameCard from './GameCard.astro';

export interface FeaturedGame {
  id: string;
  league: 'mlb' | 'kbo' | 'npb';
  homeTeam: string;
  awayTeam: string;
  homeScore?: number;
  awayScore?: number;
  inning?: string;
  status: 'live' | 'final' | 'scheduled';
  startTime?: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  featuredGame?: FeaturedGame;
  league?: 'mlb' | 'kbo' | 'npb';
}

const {
  title = "Scores, Stats & Pronostics Baseball",
  subtitle = "MLB • KBO • NPB",
  ctaText = "Voir les pronostics du jour",
  ctaHref = "/pronostics/",
  featuredGame,
  league = 'mlb'
} = Astro.props;

// League color for accent
const getLeagueColor = (league: string) => {
  switch (league) {
    case 'mlb': return 'var(--color-mlb)';
    case 'kbo': return 'var(--color-kbo)';
    case 'npb': return 'var(--color-npb)';
    default: return 'var(--color-primary)';
  }
};
---

<section
  class="hero"
  style={`--hero-accent: ${getLeagueColor(league)};`}
>
  <div class="container">
    <div class="hero-grid">
      <!-- Left column: Text + CTA -->
      <div class="hero-content">
        <h1 class="hero-title">
          {title}
        </h1>

        <p class="hero-subtitle">
          {subtitle}
        </p>

        <div class="hero-cta">
          <a href={ctaHref} class="btn btn-primary btn-large">
            {ctaText}
            <svg
              class="btn-icon"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
              />
            </svg>
          </a>

          <a href="/scores/" class="btn btn-ghost">
            Scores en direct
          </a>
        </div>

        <!-- League badges -->
        <div class="hero-leagues">
          <a href="/mlb/" class="league-badge mlb">MLB</a>
          <a href="/kbo/" class="league-badge kbo">KBO</a>
          <a href="/npb/" class="league-badge npb">NPB</a>
        </div>
      </div>

      <!-- Right column: Featured game -->
      {featuredGame && (
        <div class="hero-featured">
          <span class="hero-featured-label">Match en vedette</span>
          <GameCard {...featuredGame} variant="featured" />
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: var(--space-16) 0 var(--space-12);
    background: linear-gradient(
      135deg,
      var(--color-bg) 0%,
      var(--color-surface) 100%
    );
    overflow: hidden;
  }

  /* Decorative background element */
  .hero::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 800px;
    height: 800px;
    background: radial-gradient(
      circle,
      var(--hero-accent) 0%,
      transparent 70%
    );
    opacity: 0.05;
    pointer-events: none;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-12);
    }
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    font-weight: var(--font-extrabold);
    line-height: var(--leading-tight);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin-bottom: var(--space-4);
    background: linear-gradient(
      135deg,
      var(--color-text) 0%,
      var(--hero-accent) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--font-semibold);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-8);
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .btn-large {
    padding: var(--space-4) var(--space-8);
    font-size: var(--text-lg);
  }

  .btn-icon {
    width: 20px;
    height: 20px;
    margin-left: var(--space-2);
    transition: transform var(--transition-base);
  }

  .btn:hover .btn-icon {
    transform: translateX(4px);
  }

  .hero-leagues {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .league-badge {
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
    border: 2px solid transparent;
  }

  .league-badge.mlb {
    background-color: rgba(232, 16, 46, 0.1);
    color: var(--color-mlb);
    border-color: var(--color-mlb);
  }

  .league-badge.mlb:hover {
    background-color: var(--color-mlb);
    color: white;
  }

  .league-badge.kbo {
    background-color: rgba(0, 82, 165, 0.1);
    color: var(--color-kbo);
    border-color: var(--color-kbo);
  }

  .league-badge.kbo:hover {
    background-color: var(--color-kbo);
    color: white;
  }

  .league-badge.npb {
    background-color: rgba(230, 126, 0, 0.1);
    color: var(--color-npb);
    border-color: var(--color-npb);
  }

  .league-badge.npb:hover {
    background-color: var(--color-npb);
    color: white;
  }

  .hero-featured {
    position: relative;
  }

  .hero-featured-label {
    display: inline-block;
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--hero-accent);
    margin-bottom: var(--space-3);
    padding: var(--space-1) var(--space-3);
    background-color: rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-full);
  }

  /* Mobile adjustments */
  @media (max-width: 640px) {
    .hero {
      padding: var(--space-12) 0 var(--space-8);
    }

    .hero-title {
      font-size: var(--text-3xl);
    }

    .hero-subtitle {
      font-size: var(--text-base);
    }

    .hero-cta {
      flex-direction: column;
    }

    .btn-large {
      width: 100%;
      justify-content: center;
    }
  }
</style>
