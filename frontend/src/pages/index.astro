const standings = {
  mlb: [
    { rank: 1, team: 'Dodgers', wins: 45, losses: 28, pct: '.616' },
    { rank: 2, team: 'Yankees', wins: 43, losses: 30, pct: '.589' },
    { rank: 3, team: 'Braves', wins: 41, losses: 32, pct: '.562' },
  ],
  kbo: [
    { rank: 1, team: 'Bears', wins: 38, losses: 25, pct: '.603' },
    { rank: 2, team: 'Twins', wins: 36, losses: 27, pct: '.571' },
    { rank: 3, team: 'Heroes', wins: 34, losses: 29, pct: '.540' },
  ],
  npb: [
    { rank: 1, team: 'Giants', wins: 42, losses: 26, pct: '.618' },
    { rank: 2, team: 'Tigers', wins: 40, losses: 28, pct: '.588' },
    { rank: 3, team: 'Swallows', wins: 38, losses: 30, pct: '.559' },
  ],
};
---

<BaseLayout
  title="home-run.fr - Baseball MLB, KBO, NPB : Scores, Stats et Pronostics"
  description="Suivez les scores en direct, statistiques et pronostics pour la MLB, KBO et NPB. Votre référence baseball en français."
>
  <!-- Ticker live -->
  <Ticker items={tickerItems} speed="medium" />

  <!-- Layout 2 colonnes -->
  <div class="homepage-layout">
    <div class="container">
      <div class="layout-grid">
        <!-- Main content (75%) -->
        <main class="main-content">
          <!-- Hero title -->
          <div class="hero-section">
            <h1 class="hero-title">
              BASEBALL : ACTUALITÉS,<br>STATS & PRONOSTICS
            </h1>
            <p class="hero-subtitle">🇺🇸 MLB • 🇰🇷 KBO • 🇯🇵 NPB</p>

            <!-- Stats mini banner -->
            <div class="stats-banner">
              <span class="stat-item">⚾ 24 matchs</span>
              <span class="stat-separator">|</span>
              <span class="stat-item">🔴 3 live</span>
              <span class="stat-separator">|</span>
              <span class="stat-item">📊 12 pronostics</span>
            </div>
          </div>

          <!-- Actualités EN PREMIER (priorité éditoriale) -->
          <section class="section-news">
            <div class="section-header">
              <h2 class="section-title">À LA UNE</h2>
              <a href="/news/" class="section-link">Toutes les news →</a>
            </div>

            <div class="news-grid">
              {recentNews.map((article, index) => (
                <article class={`news-card ${index === 0 ? 'news-featured' : ''}`}>
                  <a href={`/news/${article.slug}/`} class="news-link">
                    <div class="news-image-wrapper">
                      <img
                        src={`/images/news/${article.slug}.jpg`}
                        alt={article.title}
                        class="news-image"
                        loading="lazy"
                      />
                    </div>
                    <div class="news-content">
                      <div class="news-category">
                        {article.league === 'mlb' && '🇺🇸 MLB'}
                        {article.league === 'kbo' && '🇰🇷 KBO'}
                        {article.league === 'npb' && '🇯🇵 NPB'}
                        <span class="category-sep">•</span>
                        {article.category}
                      </div>
                      <h3 class="news-title">{article.title}</h3>
                      <p class="news-excerpt">{article.excerpt}</p>
                      <div class="news-date">{new Date(article.publishedAt).toLocaleDateString('fr-FR')}</div>
                    </div>
                  </a>
                </article>
              ))}
            </div>
          </section>

          <!-- Pronostics EN SECOND (monétisation discrète) -->
          <section class="section-pronostics">
            <div class="section-header">
              <h2 class="section-title">PRONOSTICS <span>DU JOUR</span></h2>
              <a href="/pronostics/" class="section-link">Tous les pronostics →</a>
            </div>

            <div class="pronostics-grid">
              <!-- Prono 1 -->
              <div class="prono-card">
                <h3 class="prono-title">🇺🇸 MLB YANKEES VS DODGERS</h3>
                <p class="prono-time">Aujourd'hui 20:05</p>
                <p class="prono-excerpt">
                  Les Dodgers, portés par la forme olympique de Shohei Ohtani, partent favoris face à des Yankees affaiblis par les blessures.
                </p>
                <div class="prono-cotes">
                  <div class="cote-item">
                    <span class="cote-team">Yankees</span>
                    <span class="cote-value">1.85</span>
                  </div>
                  <span class="cote-separator">•</span>
                  <div class="cote-item">
                    <span class="cote-team">Dodgers</span>
                    <span class="cote-value">2.10</span>
                  </div>
                </div>
                <a href="/pronostics/mlb/yankees-dodgers/" class="btn-prono">Voir le pronostic</a>
              </div>

              <!-- Prono 2 -->
              <div class="prono-card">
                <h3 class="prono-title">🇰🇷 KBO BEARS VS TWINS</h3>
                <p class="prono-time">Aujourd'hui 18:30</p>
                <p class="prono-excerpt">
                  Les Doosan Bears enchaînent les victoires. Sur une série de 5 matchs gagnés, ils sont clairement supérieurs.
                </p>
                <div class="prono-cotes">
                  <div class="cote-item">
                    <span class="cote-team">Bears</span>
                    <span class="cote-value">1.95</span>
                  </div>
                  <span class="cote-separator">•</span>
                  <div class="cote-item">
                    <span class="cote-team">Twins</span>
                    <span class="cote-value">1.88</span>
                  </div>
                </div>
                <a href="/pronostics/kbo/bears-twins/" class="btn-prono">Voir le pronostic</a>
              </div>
            </div>
          </section>

          <!-- Top joueurs -->
          <section class="section-players">
            <div class="section-header">
              <h2 class="section-title">TOP JOUEURS</h2>
              <a href="/mlb/joueurs/" class="section-link">Tous les joueurs →</a>
            </div>

            <div class="players-grid">
              {topPlayers.map((player) => (
                <PlayerCard {...player} />
              ))}
            </div>
          </section>
        </main>

        <!-- Sidebar (25%) sticky -->
        <aside class="sidebar">
          <div class="sidebar-sticky">
            <!-- Scores Live -->
            <div class="sidebar-section">
              <div class="sidebar-header">
                <h3 class="sidebar-title">🔴 SCORES LIVE</h3>
              </div>

              <div class="sidebar-games">
                {sidebarGames.map((game) => (
                  <div class="live-match-card">
                    <div class="match-header">
                      <span class={`league-badge ${game.league.toLowerCase()}`}>
                        {game.league === 'MLB' && '🇺🇸 MLB'}
                        {game.league === 'KBO' && '🇰🇷 KBO'}
                        {game.league === 'NPB' && '🇯🇵 NPB'}
                      </span>
                      {game.status === 'live' && (
                        <span class="live-badge">EN DIRECT</span>
                      )}
                    </div>

                    <div class="match-teams">
                      <div class="team-row">
                        <div class="team-info">
                          <span class="team-logo">{game.awayTeam.substring(0, 3).toUpperCase()}</span>
                          <span class="team-name">{game.awayTeam}</span>
                        </div>
                        <span class="team-score">{game.awayScore}</span>
                      </div>

                      <div class="team-row">
                        <div class="team-info">
                          <span class="team-logo">{game.homeTeam.substring(0, 3).toUpperCase()}</span>
                          <span class="team-name">{game.homeTeam}</span>
                        </div>
                        <span class="team-score">{game.homeScore}</span>
                      </div>
                    </div>

                    {game.inning && (
                      <div class="match-status">{game.inning}</div>
                    )}
                  </div>
                ))}
              </div>

              <a href="/scores/" class="sidebar-link">Voir tous les matchs →</a>
            </div>

            <!-- Classements -->
            <div class="sidebar-section">
              <div class="sidebar-header">
                <h3 class="sidebar-title">📊 CLASSEMENTS</h3>
              </div>

              <div class="standings-widget">
                <!-- MLB -->
                <div class="standings-league">
                  <div class="standings-league-header">🇺🇸 MLB</div>
                  <div class="standings-list">
                    {standings.mlb.map((team) => (
                      <div class="standings-row">
                        <span class="standings-rank">{team.rank}</span>
                        <span class="standings-team">{team.team}</span>
                        <span class="standings-record">{team.wins}-{team.losses}</span>
                      </div>
                    ))}
                  </div>
                </div>

                <!-- KBO -->
                <div class="standings-league">
                  <div class="standings-league-header">🇰🇷 KBO</div>
                  <div class="standings-list">
                    {standings.kbo.map((team) => (
                      <div class="standings-row">
                        <span class="standings-rank">{team.rank}</span>
                        <span class="standings-team">{team.team}</span>
                        <span class="standings-record">{team.wins}-{team.losses}</span>
                      </div>
                    ))}
                  </div>
                </div>

                <!-- NPB -->
                <div class="standings-league">
                  <div class="standings-league-header">🇯🇵 NPB</div>
                  <div class="standings-list">
                    {standings.npb.map((team) => (
                      <div class="standings-row">
                        <span class="standings-rank">{team.rank}</span>
                        <span class="standings-team">{team.team}</span>
                        <span class="standings-record">{team.wins}-{team.losses}</span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>

              <a href="/classements/" class="sidebar-link">Tous les classements →</a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <!-- Betting strip ANJ -->
  <BettingStrip bookmakers={anjBookmakers} variant="horizontal" />
</BaseLayout>

<style>
  .homepage-layout {
    padding: 16px 0;
  }

  .layout-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 48px;
    align-items: start;
  }

  @media (max-width: 1024px) {
    .layout-grid {
      grid-template-columns: 1fr;
    }

    .sidebar {
      display: none;
    }
  }

  /* MAIN CONTENT */
  .main-content {
    min-width: 0;
  }

  /* Hero */
  .hero-section {
    padding: 24px 0 16px 0;
    margin-bottom: 0;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: 56px !important;
    line-height: 1.2;
    letter-spacing: -1.5px;
    font-weight: 900;
    background: linear-gradient(135deg, #e8102e 0%, #0052a5 50%, #e67e00 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 16px;
  }

  @media (max-width: 1024px) {
    .hero-title {
      font-size: 42px !important;
    }
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 36px !important;
    }
  }

  .hero-subtitle {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  /* Stats banner */
  .stats-banner {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-4);
    background-color: var(--color-surface);
    border-radius: var(--radius-full);
    width: fit-content;
  }

  .stat-item {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-text);
  }

  .stat-separator {
    color: var(--color-text-muted);
  }

  /* Sections */
  .section-news {
    margin-top: 32px;
    margin-bottom: 32px;
  }

  .section-pronostics {
    margin-top: 32px;
    margin-bottom: 32px;
  }

  .section-players {
    margin-top: 32px;
    margin-bottom: 32px;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-6);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 800;
    letter-spacing: -0.5px;
    text-transform: uppercase;
    color: var(--color-text);
  }

  .section-news .section-title {
    font-size: 40px;
    margin-bottom: 32px;
  }

  .section-title span {
    color: var(--color-red);
  }

  .section-link {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .section-link:hover {
    color: var(--color-red);
  }

  /* Pronostics */
  .pronostics-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  @media (max-width: 768px) {
    .pronostics-grid {
      grid-template-columns: 1fr;
    }
  }

  .prono-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 16px;
    transition: all 0.3s ease;
  }

  .prono-card:hover {
    border-color: var(--color-border-strong);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .prono-title {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.3px;
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: 4px;
  }

  .prono-time {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-bottom: 12px;
  }

  .prono-excerpt {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin-bottom: 12px;
  }

  .prono-cotes {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 12px;
    background-color: var(--color-surface-2);
    border-radius: var(--radius-md);
    margin-bottom: 12px;
  }

  .cote-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .cote-team {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .cote-value {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 800;
    color: var(--color-text);
  }

  .cote-separator {
    font-size: 20px;
    color: var(--color-text-muted);
    padding: 0 8px;
  }

  .btn-prono {
    display: block;
    width: 100%;
    padding: 10px 20px;
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    text-align: center;
    text-decoration: none;
    letter-spacing: 0.05em;
    color: white !important;
    background-color: var(--color-red);
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
  }

  .btn-prono:hover {
    background-color: var(--color-red-dim);
    box-shadow: 0 0 24px rgba(232, 16, 46, 0.3);
  }

  /* News */
  .news-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  @media (max-width: 1024px) {
    .news-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .news-grid {
      grid-template-columns: 1fr;
    }
  }

  .news-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  /* Première card en vedette - full width */
  .news-card.news-featured {
    grid-column: span 3;
  }

  .news-card.news-featured .news-image {
    height: 300px;
  }

  .news-card.news-featured .news-title {
    font-size: 24px;
  }

  @media (max-width: 1024px) {
    .news-card.news-featured {
      grid-column: span 2;
    }
  }

  @media (max-width: 640px) {
    .news-card.news-featured {
      grid-column: span 1;
    }

    .news-card.news-featured .news-image {
      height: 200px;
    }

    .news-card.news-featured .news-title {
      font-size: 18px;
    }
  }

  .news-card:hover {
    border-color: var(--color-border-strong);
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .news-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .news-image-wrapper {
    width: 100%;
    height: 200px;
    overflow: hidden;
    background-color: var(--color-surface-2);
  }

  .news-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .news-card:hover .news-image {
    transform: scale(1.05);
  }

  .news-content {
    padding: 20px;
  }

  .news-category {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .category-sep {
    margin: 0 var(--space-1);
  }

  .news-title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.3px;
    line-height: 1.4;
    color: var(--color-text);
    margin-bottom: 12px;
  }

  .news-excerpt {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
