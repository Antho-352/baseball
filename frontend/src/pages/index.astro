import NewsGrid from '@components/ui/NewsGrid.astro';
import BettingStrip from '@components/ui/BettingStrip.astro';
import StandingsTable from '@components/ui/StandingsTable.astro';
import Button from '@components/ui/Button.astro';
import Card from '@components/ui/Card.astro';
import StatWidget from '@components/ui/StatWidget.astro';

// Mock data (sera remplacé par API calls)

