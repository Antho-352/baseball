---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="home-run.fr - Baseball MLB, KBO, NPB : Scores, Stats et Pronostics"
  description="Suivez les scores en direct, les statistiques et les pronostics pour la MLB, KBO et NPB. Votre référence baseball en français."
>
  <div class="container mx-auto py-16">
    <header class="text-center mb-12">
      <h1 class="text-5xl font-bold mb-4">
        ⚾ home-run.fr
      </h1>
      <p class="text-xl text-muted">
        Baseball MLB, KBO, NPB : Scores, Stats et Pronostics
      </p>
    </header>

    <main class="max-w-3xl mx-auto">
      <section class="card mb-8">
        <h2 class="text-3xl font-bold mb-4">Design System Test</h2>

        <div class="space-y-6">
          <!-- Colors -->
          <div>
            <h3 class="text-xl font-semibold mb-3">Couleurs</h3>
            <div class="grid grid-cols-4 gap-4">
              <div>
                <div class="h-12 rounded bg-primary"></div>
                <p class="text-sm mt-1">Primary</p>
              </div>
              <div>
                <div class="h-12 rounded bg-secondary"></div>
                <p class="text-sm mt-1">Secondary</p>
              </div>
              <div>
                <div class="h-12 rounded bg-success"></div>
                <p class="text-sm mt-1">Success</p>
              </div>
              <div>
                <div class="h-12 rounded bg-error"></div>
                <p class="text-sm mt-1">Error</p>
              </div>
            </div>
          </div>

          <!-- Typography -->
          <div>
            <h3 class="text-xl font-semibold mb-3">Typographie</h3>
            <h1 class="text-4xl font-bold">H1 - Heading 4xl</h1>
            <h2 class="text-3xl font-bold">H2 - Heading 3xl</h2>
            <h3 class="text-2xl font-bold">H3 - Heading 2xl</h3>
            <p class="text-base">Paragraphe standard (16px base)</p>
            <p class="text-sm text-muted">Texte secondaire (14px muted)</p>
          </div>

          <!-- Buttons -->
          <div>
            <h3 class="text-xl font-semibold mb-3">Boutons</h3>
            <div class="flex gap-4">
              <button class="btn btn-primary">Primary</button>
              <button class="btn btn-secondary">Secondary</button>
              <button class="btn btn-ghost">Ghost</button>
              <button class="btn btn-primary" disabled>Disabled</button>
            </div>
          </div>

          <!-- Badges -->
          <div>
            <h3 class="text-xl font-semibold mb-3">Badges</h3>
            <div class="flex gap-3">
              <span class="badge badge-live">EN DIRECT</span>
              <span class="badge" style="background-color: var(--color-success-bg); color: var(--color-success);">TERMINÉ</span>
              <span class="badge" style="background-color: var(--color-warning-bg); color: var(--color-warning);">REPORTÉ</span>
            </div>
          </div>

          <!-- Score Board -->
          <div>
            <h3 class="text-xl font-semibold mb-3">Score Board</h3>
            <div class="score-board border border-border rounded-lg p-6">
              <div class="score-board-team">Yankees</div>
              <div class="score-board-score">
                <span>5</span>
                <span class="text-muted mx-2">-</span>
                <span>3</span>
              </div>
              <div class="score-board-team">Red Sox</div>
            </div>
          </div>

          <!-- Dark Mode Toggle -->
          <div>
            <h3 class="text-xl font-semibold mb-3">Dark Mode</h3>
            <button
              id="theme-toggle"
              class="btn btn-ghost"
            >
              <span id="theme-icon">🌙</span>
              <span class="ml-2">Toggle Dark Mode</span>
            </button>
          </div>
        </div>
      </section>

      <footer class="text-center text-muted text-sm">
        <p>Design system test - Tokens CSS + Tailwind hybrid</p>
      </footer>
    </main>
  </div>
</BaseLayout>

<script>
  // Dark mode toggle
  const toggle = document.getElementById('theme-toggle');
  const icon = document.getElementById('theme-icon');

  if (toggle && icon) {
    toggle.addEventListener('click', () => {
      const html = document.documentElement;
      const current = html.dataset.theme;
      const next = current === 'dark' ? 'light' : 'dark';

      html.dataset.theme = next;
      localStorage.setItem('theme', next);

      icon.textContent = next === 'dark' ? '☀️' : '🌙';
    });

    // Set initial icon
    const current = document.documentElement.dataset.theme;
    icon.textContent = current === 'dark' ? '☀️' : '🌙';
  }
</script>
