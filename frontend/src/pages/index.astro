---

<BaseLayout
  title="home-run.fr - Baseball MLB, KBO, NPB : Scores, Stats et Pronostics"
  description="Suivez les scores en direct, statistiques et pronostics pour la MLB, KBO et NPB. Votre référence baseball en français."
>
  <!-- Ticker live -->
  <Ticker items={tickerItems} speed="medium" />

  <!-- Layout 2 colonnes -->
  <div class="homepage-layout">
    <div class="container">
      <div class="layout-grid">
        <!-- Main content (75%) -->
        <main class="main-content">
          <!-- Hero title -->
          <div class="hero-section">
            <h1 class="hero-title">
              SCORES, STATS &<br>PRONOSTICS<br>BASEBALL
            </h1>
            <p class="hero-subtitle">🇺🇸 MLB • 🇰🇷 KBO • 🇯🇵 NPB</p>

            <!-- Stats mini banner -->
            <div class="stats-banner">
              <span class="stat-item">⚾ 24 matchs</span>
              <span class="stat-separator">|</span>
              <span class="stat-item">🔴 3 live</span>
              <span class="stat-separator">|</span>
              <span class="stat-item">📊 12 pronostics</span>
            </div>
          </div>

          <!-- Pronostics du jour -->
          <section class="section-pronostics">
            <div class="section-header">
              <h2 class="section-title">PRONOSTICS <span>DU JOUR</span></h2>
              <a href="/pronostics/" class="section-link">Tous les pronostics →</a>
            </div>

            <div class="pronostics-grid">
              <!-- Prono 1 -->
              <div class="prono-card">
                <div class="prono-header">
                  <div class="prono-match">
                    <h3 class="prono-title">🇺🇸 MLB Yankees vs Dodgers</h3>
                    <p class="prono-time">Aujourd'hui 20:05</p>
                  </div>
                  <span class="badge-confiance-high">CONFIANCE ÉLEVÉE</span>
                </div>
                <p class="prono-excerpt">
                  Les Dodgers, portés par la forme olympique de Shohei Ohtani, partent favoris face à des Yankees affaiblis par les blessures.
                </p>
                <div class="prono-cote">
                  <div class="cote-label">Cote</div>
                  <div class="cote-value">1.85</div>
                </div>
                <a href="/pronostics/mlb/yankees-dodgers/" class="btn-prono">Voir le pronostic</a>
              </div>

              <!-- Prono 2 -->
              <div class="prono-card">
                <div class="prono-header">
                  <div class="prono-match">
                    <h3 class="prono-title">🇰🇷 KBO Bears vs Twins</h3>
                    <p class="prono-time">Aujourd'hui 18:30</p>
                  </div>
                  <span class="badge-confiance-medium">VALEUR</span>
                </div>
                <p class="prono-excerpt">
                  Les Doosan Bears enchaînent les victoires. Sur une série de 5 matchs gagnés, ils sont clairement supérieurs.
                </p>
                <div class="prono-cote">
                  <div class="cote-label">Cote</div>
                  <div class="cote-value">2.10</div>
                </div>
                <a href="/pronostics/kbo/bears-twins/" class="btn-prono">Voir le pronostic</a>
              </div>
            </div>
          </section>

          <!-- Actualités -->
          <section class="section-news">
            <div class="section-header">
              <h2 class="section-title">ACTUALITÉS</h2>
              <a href="/news/" class="section-link">Toutes les news →</a>
            </div>

            <div class="news-grid">
              {recentNews.map((article) => (
                <article class="news-card">
                  <a href={`/news/${article.slug}/`} class="news-link">
                    <div class="news-category">
                      {article.league === 'mlb' && '🇺🇸 MLB'}
                      {article.league === 'kbo' && '🇰🇷 KBO'}
                      {article.league === 'npb' && '🇯🇵 NPB'}
                      <span class="category-sep">•</span>
                      {article.category}
                    </div>
                    <h3 class="news-title">{article.title}</h3>
                    <p class="news-excerpt">{article.excerpt}</p>
                    <div class="news-date">{new Date(article.publishedAt).toLocaleDateString('fr-FR')}</div>
                  </a>
                </article>
              ))}
            </div>
          </section>

          <!-- Top joueurs -->
          <section class="section-players">
            <div class="section-header">
              <h2 class="section-title">TOP JOUEURS</h2>
              <a href="/mlb/joueurs/" class="section-link">Tous les joueurs →</a>
            </div>

            <div class="players-grid">
              {topPlayers.map((player) => (
                <PlayerCard {...player} />
              ))}
            </div>
          </section>
        </main>

        <!-- Sidebar (25%) sticky -->
        <aside class="sidebar">
          <div class="sidebar-sticky">
            <div class="sidebar-header">
              <h3 class="sidebar-title">🔴 SCORES LIVE</h3>
            </div>

            <div class="sidebar-games">
              {sidebarGames.map((game) => (
                <GameCard {...game} class="sidebar-game-card" />
              ))}
            </div>

            <a href="/scores/" class="sidebar-link">Voir tous les matchs →</a>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <!-- Betting strip ANJ -->
  <BettingStrip bookmakers={anjBookmakers} variant="horizontal" />
</BaseLayout>

<style>
  .homepage-layout {
    padding: var(--space-8) 0;
  }

  .layout-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: var(--space-8);
    align-items: start;
  }

  @media (max-width: 1024px) {
    .layout-grid {
      grid-template-columns: 1fr;
    }

    .sidebar {
      display: none;
    }
  }

  /* MAIN CONTENT */
  .main-content {
    min-width: 0;
  }

  /* Hero */
  .hero-section {
    margin-bottom: var(--space-12);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: 72px;
    line-height: 1.1;
    letter-spacing: -2px;
    font-weight: 900;
    background: linear-gradient(135deg, #e8102e 0%, #0052a5 50%, #e67e00 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: var(--space-4);
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 48px;
    }
  }

  .hero-subtitle {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  /* Stats banner */
  .stats-banner {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-4);
    background-color: var(--color-surface);
    border-radius: var(--radius-full);
    width: fit-content;
  }

  .stat-item {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-text);
  }

  .stat-separator {
    color: var(--color-text-muted);
  }

  /* Sections */
  .section-pronostics,
  .section-news,
  .section-players {
    margin-bottom: var(--space-12);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-6);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 800;
    letter-spacing: -0.5px;
    text-transform: uppercase;
    color: var(--color-text);
  }

  .section-title span {
    color: var(--color-red);
  }

  .section-link {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .section-link:hover {
    color: var(--color-red);
  }

  /* Pronostics */
  .pronostics-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  @media (max-width: 768px) {
    .pronostics-grid {
      grid-template-columns: 1fr;
    }
  }

  .prono-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 24px;
    transition: all 0.3s ease;
  }

  .prono-card:hover {
    border-color: var(--color-border-strong);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .prono-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .prono-match {
    flex: 1;
  }

  .prono-title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.3px;
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: var(--space-1);
  }

  .prono-time {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .badge-confiance-high,
  .badge-confiance-medium {
    padding: 4px 12px;
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-radius: var(--radius-full);
    white-space: nowrap;
  }

  .badge-confiance-high {
    background-color: rgba(0, 255, 136, 0.12);
    color: var(--color-green);
  }

  .badge-confiance-medium {
    background-color: rgba(245, 158, 11, 0.12);
    color: var(--color-gold);
  }

  .prono-excerpt {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }

  .prono-cote {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3);
    background-color: var(--color-surface-2);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-4);
  }

  .cote-label {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .cote-value {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 800;
    color: var(--color-text);
  }

  .btn-prono {
    display: block;
    width: 100%;
    padding: 12px 24px;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    text-align: center;
    text-decoration: none;
    letter-spacing: 0.05em;
    color: white;
    background-color: var(--color-red);
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
  }

  .btn-prono:hover {
    background-color: var(--color-red-dim);
    box-shadow: 0 0 24px rgba(232, 16, 46, 0.3);
  }

  /* News */
  .news-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  @media (max-width: 1024px) {
    .news-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .news-grid {
      grid-template-columns: 1fr;
    }
  }

  .news-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 24px;
    transition: all 0.3s ease;
  }

  .news-card:hover {
    border-color: var(--color-border-strong);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .news-link {
    text-decoration: none;
    color: inherit;
  }

  .news-category {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .category-sep {
    margin: 0 var(--space-1);
  }

  .news-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.3px;
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .news-excerpt {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-3);
  }

  .news-date {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  /* Players */
  .players-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  @media (max-width: 1024px) {
    .players-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .players-grid {
      grid-template-columns: 1fr;
    }
  }

  /* SIDEBAR */
  .sidebar {
    position: relative;
  }

  .sidebar-sticky {
    position: sticky;
    top: 80px;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: var(--space-5);
  }

  .sidebar-header {
    margin-bottom: var(--space-4);
  }

  .sidebar-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--color-text);
  }

  .sidebar-games {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .sidebar-link {
    display: block;
    padding: var(--space-2);
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    text-align: center;
    text-decoration: none;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    transition: color var(--transition-base);
  }

  .sidebar-link:hover {
    color: var(--color-red);
  }
</style>
