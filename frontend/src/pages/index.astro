    gameId: 'mlb-1',
    league: 'MLB',
    inning: 'T7',
  },
  {
    homeTeam: 'Doosan Bears',
    awayTeam: 'LG Twins',
    homeScore: 7,
    awayScore: 4,
    status: 'final' as const,
    startTime: new Date(),
    gameId: 'kbo-1',
    league: 'KBO',
  },
  {
    homeTeam: 'Yomiuri Giants',
