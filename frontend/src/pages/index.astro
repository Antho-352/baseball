---
/**
 * Homepage - Layout 2 colonnes (75% main / 25% sidebar)
 * Design system appliqué strictement
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import Ticker from '@components/ui/Ticker.astro';
import GameCard from '@components/ui/GameCard.astro';
