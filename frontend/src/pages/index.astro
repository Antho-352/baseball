    publishedAt: '2026-04-13',
    slug: 'world-series-favoris',
  },
  {
    id: '3',
    title: 'KBO : Les Bears enchaînent 5 victoires',
    excerpt: 'Doosan confirme sa forme avec une nouvelle victoire face aux Twins.',
    category: 'News',
    league: 'kbo' as const,
    publishedAt: '2026-04-12',
    slug: 'kbo-bears-serie',
  },
  {
    id: '4',
    title: 'Aaron Judge bat un record personnel',
    excerpt: '58e home run de la saison pour le capitaine des Yankees.',
    category: 'Stats',
    league: 'mlb' as const,
    publishedAt: '2026-04-11',
    slug: 'judge-58-hr',
  },
];

const anjBookmakers = [
  {
    name: 'Betclic',
    affiliateUrl: '/paris-sportifs/betclic/',
    bonus: 'Jusqu\'à 100€ offerts',
  },
  {
    name: 'Unibet',
    affiliateUrl: '/paris-sportifs/unibet/',
    bonus: '50€ de bonus',
  },
  {
    name: 'Winamax',
    affiliateUrl: '/paris-sportifs/winamax/',
    bonus: '100€ de paris gratuits',
