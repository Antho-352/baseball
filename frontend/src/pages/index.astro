  {
    name: 'Shohei Ohtani',
    position: 'DH',
    teamName: 'Los Angeles Dodgers',
    stats: [
      { label: 'AVG', value: '.304' },
      { label: 'HR', value: '44' },
      { label: 'RBI', value: '95' },
    ],
    playerId: 'shohei-ohtani',
    league: 'MLB',
  },
  {
    name: 'Aaron Judge',
    position: 'RF',
    teamName: 'New York Yankees',
    stats: [
      { label: 'AVG', value: '.311' },
      { label: 'HR', value: '58' },
      { label: 'RBI', value: '144' },
    ],
    playerId: 'aaron-judge',
    league: 'MLB',
  },
  {
    name: 'Mookie Betts',
    position: 'RF',
    teamName: 'Los Angeles Dodgers',
    stats: [
      { label: 'AVG', value: '.307' },
      { label: 'HR', value: '35' },
      { label: 'RBI', value: '82' },
    ],
    playerId: 'mookie-betts',
    league: 'MLB',
  },
];

const recentNews = [
  {
    id: '1',
    title: 'Shohei Ohtani signe le plus gros contrat de l\'histoire',
    excerpt: 'Le joueur japonais rejoint les Dodgers pour 700 millions de dollars sur 10 ans.',
    category: 'Transferts',
