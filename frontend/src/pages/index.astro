---
/**
 * Homepage - Hub multi-ligues
 *
 * Sections:
 * - Hero avec titre + tagline
 * - Scores du jour (MLB, KBO, NPB)
 * - Pronostics à la une
 * - Top joueurs
 * - News récentes
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import Ticker from '@components/ui/Ticker.astro';
