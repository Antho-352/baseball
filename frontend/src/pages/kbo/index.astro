---
/**
 * Hub KBO - Page principale de la ligue KBO (Corée du Sud)
 *
 * Sections:
 * - Hero KBO avec navigation rapide
 * - Scores du jour
 * - Classement KBO
 * - Stats leaders
 * - News KBO récentes
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import GameCard from '@components/ui/GameCard.astro';
import StandingsTable from '@components/ui/StandingsTable.astro';
import StatWidget from '@components/ui/StatWidget.astro';
import Card from '@components/ui/Card.astro';
import Button from '@components/ui/Button.astro';

// Mock data - sera remplacé par TheSportsDBProvider
const todayGamesKBO = [
  {
    homeTeam: 'Doosan Bears',
    awayTeam: 'LG Twins',
    homeScore: 7,
    awayScore: 4,
    status: 'final' as const,
    startTime: new Date(Date.now() - 7200000),
    gameId: 'kbo-2026-04-15-lg-doo',
    league: 'KBO',
  },
  {
    homeTeam: 'Samsung Lions',
    awayTeam: 'KIA Tigers',
    homeScore: 3,
    awayScore: 2,
    status: 'live' as const,
    startTime: new Date(),
    gameId: 'kbo-2026-04-15-kia-sam',
    league: 'KBO',
  },
  {
    homeTeam: 'Kiwoom Heroes',
    awayTeam: 'NC Dinos',
    homeScore: null,
    awayScore: null,
    status: 'scheduled' as const,
    startTime: new Date(Date.now() + 7200000),
    gameId: 'kbo-2026-04-15-nc-kiw',
    league: 'KBO',
  },
];

const standingsKBO = [
  { rank: 1, teamName: 'Doosan Bears', wins: 18, losses: 7, pct: 0.720, gb: 0, streak: 'W5' },
  { rank: 2, teamName: 'LG Twins', wins: 16, losses: 9, pct: 0.640, gb: 2.0, streak: 'L1' },
  { rank: 3, teamName: 'Samsung Lions', wins: 15, losses: 10, pct: 0.600, gb: 3.0, streak: 'W2' },
  { rank: 4, teamName: 'KIA Tigers', wins: 14, losses: 11, pct: 0.560, gb: 4.0, streak: 'W1' },
  { rank: 5, teamName: 'Kiwoom Heroes', wins: 13, losses: 12, pct: 0.520, gb: 5.0, streak: 'L2' },
  { rank: 6, teamName: 'NC Dinos', wins: 12, losses: 13, pct: 0.480, gb: 6.0, streak: 'W3' },
  { rank: 7, teamName: 'Lotte Giants', wins: 11, losses: 14, pct: 0.440, gb: 7.0, streak: 'L1' },
  { rank: 8, teamName: 'KT Wiz', wins: 10, losses: 15, pct: 0.400, gb: 8.0, streak: 'L3' },
  { rank: 9, teamName: 'Hanwha Eagles', wins: 9, losses: 16, pct: 0.360, gb: 9.0, streak: 'L2' },
  { rank: 10, teamName: 'SSG Landers', wins: 8, losses: 17, pct: 0.320, gb: 10.0, streak: 'W1' },
];

const recentNewsKBO = [
  {
    title: 'KBO : Les Doosan Bears enchaînent une 5e victoire consécutive',
    excerpt: 'Doosan confirme sa domination avec une victoire éclatante 7-4 face aux LG Twins...',
    date: '2026-04-15',
    slug: 'bears-5-victoires-consecutives',
  },
  {
    title: 'Samsung Lions : Le retour en force après la blessure de leur ace',
    excerpt: 'Malgré l\'absence de leur meilleur lanceur, les Lions restent compétitifs...',
    date: '2026-04-14',
    slug: 'samsung-lions-retour-forme',
  },
  {
    title: 'KBO 2026 : Analyse des favoris pour le titre',
    excerpt: 'Avec un quart de saison disputé, les Doosan Bears et LG Twins se démarquent...',
    date: '2026-04-13',
    slug: 'kbo-2026-favoris-titre',
  },
];
---

<BaseLayout
  title="KBO : Scores en Direct, Classement et Calendrier | home-run.fr"
  description="Suivez le championnat coréen KBO en direct : scores live, classement, statistiques et actualités baseball coréen en français."
>
  <!-- Hero KBO -->
  <section class="bg-gradient-to-r from-red-800 to-red-600 text-white py-12">
    <div class="container mx-auto">
      <div class="flex items-center gap-4 mb-6">
        <div class="text-6xl">🇰🇷</div>
        <div>
          <h1 class="text-4xl md:text-5xl font-extrabold mb-2">
            KBO - Korean Baseball Organization
          </h1>
          <p class="text-xl text-red-100">
            Saison 2026 - Championnat de Corée du Sud
          </p>
        </div>
      </div>

      <!-- Quick nav -->
      <div class="flex flex-wrap gap-3">
        <Button variant="secondary" size="sm" href="/kbo/scores/">
          Scores du jour
        </Button>
        <Button variant="ghost" size="sm" href="/kbo/calendrier/" class="!text-white !border-white hover:!bg-white/10">
          Calendrier
        </Button>
        <Button variant="ghost" size="sm" href="/kbo/classement/" class="!text-white !border-white hover:!bg-white/10">
          Classement complet
        </Button>
        <Button variant="ghost" size="sm" href="/kbo/equipes/" class="!text-white !border-white hover:!bg-white/10">
          Équipes
        </Button>
        <Button variant="ghost" size="sm" href="/kbo/joueurs/" class="!text-white !border-white hover:!bg-white/10">
          Joueurs
        </Button>
      </div>
    </div>
  </section>

  <!-- Stats overview -->
  <section class="py-8 bg-bg-surface border-b border-border">
    <div class="container mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <StatWidget
          label="Matchs aujourd'hui"
          value="5"
          icon="⚾"
        />
        <StatWidget
          label="Matchs live"
          value="1"
          icon="🔴"
        />
        <StatWidget
          label="Équipes"
          value="10"
          subtitle="KBO League"
          icon="🏟️"
        />
        <StatWidget
          label="Saison"
          value="2026"
          subtitle="En cours"
          icon="📅"
        />
      </div>
    </div>
  </section>

  <!-- Scores du jour -->
  <section class="section">
    <div class="container mx-auto">
      <div class="flex justify-between items-center mb-6">
        <h2 class="text-3xl font-bold">Scores du jour</h2>
        <Button variant="ghost" size="sm" href="/kbo/scores/">
          Tous les matchs KBO →
        </Button>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {todayGamesKBO.map((game) => (
          <GameCard {...game} />
        ))}
      </div>
    </div>
  </section>

  <!-- Classement -->
  <section class="section bg-bg-surface">
    <div class="container mx-auto">
      <div class="flex justify-between items-center mb-6">
        <h2 class="text-3xl font-bold">Classement KBO 2026</h2>
        <Button variant="ghost" size="sm" href="/kbo/classement/">
          Classement détaillé →
        </Button>
      </div>

      <StandingsTable standings={standingsKBO} highlightTop={3} />
    </div>
  </section>

  <!-- Stats leaders -->
  <section class="section">
    <div class="container mx-auto">
      <h2 class="text-3xl font-bold mb-6">Leaders statistiques KBO</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Batteurs -->
        <Card variant="bordered" padding="lg">
          <h3 class="text-xl font-bold mb-4">🏏 Top batteurs (AVG)</h3>
          <div class="space-y-3">
            {[
              { player: 'Yang Eui-ji', team: 'NC Dinos', stat: '.365' },
              { player: 'Kim Hyun-soo', team: 'LG Twins', stat: '.348' },
              { player: 'Park Byung-ho', team: 'KT Wiz', stat: '.337' },
              { player: 'Na Sung-bum', team: 'KIA Tigers', stat: '.325' },
              { player: 'Choi Jeong', team: 'SK Wyverns', stat: '.318' },
            ].map((item, index) => (
              <div class="flex justify-between items-center py-2 border-b border-border last:border-0">
                <div class="flex items-center gap-3">
                  <span class="font-bold text-text-muted w-6">{index + 1}</span>
                  <div>
                    <div class="font-semibold">{item.player}</div>
                    <div class="text-xs text-text-muted">{item.team}</div>
                  </div>
                </div>
                <span class="text-2xl font-bold tabular-nums">{item.stat}</span>
              </div>
            ))}
          </div>
        </Card>

        <!-- Home runs -->
        <Card variant="bordered" padding="lg">
          <h3 class="text-xl font-bold mb-4">💥 Top home runs</h3>
          <div class="space-y-3">
            {[
              { player: 'Park Byung-ho', team: 'KT Wiz', stat: '22' },
              { player: 'Choi Jeong', team: 'SK Wyverns', stat: '19' },
              { player: 'Yang Eui-ji', team: 'NC Dinos', stat: '18' },
              { player: 'Na Sung-bum', team: 'KIA Tigers', stat: '16' },
              { player: 'Lee Dae-ho', team: 'Lotte Giants', stat: '15' },
            ].map((item, index) => (
              <div class="flex justify-between items-center py-2 border-b border-border last:border-0">
                <div class="flex items-center gap-3">
                  <span class="font-bold text-text-muted w-6">{index + 1}</span>
                  <div>
                    <div class="font-semibold">{item.player}</div>
                    <div class="text-xs text-text-muted">{item.team}</div>
                  </div>
                </div>
                <span class="text-2xl font-bold tabular-nums">{item.stat}</span>
              </div>
            ))}
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- News KBO -->
  <section class="section bg-bg-surface">
    <div class="container mx-auto">
      <div class="flex justify-between items-center mb-6">
        <h2 class="text-3xl font-bold">Actualités KBO</h2>
        <Button variant="ghost" size="sm" href="/news/kbo/">
          Toutes les news KBO →
        </Button>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {recentNewsKBO.map((article) => (
          <Card variant="bordered" padding="md" class="hover:shadow-lg transition-shadow">
            <div class="mb-3">
              <span class="text-xs font-semibold text-primary uppercase tracking-wide">
                KBO
              </span>
              <span class="text-xs text-text-muted ml-2">
                {new Date(article.date).toLocaleDateString('fr-FR')}
              </span>
            </div>
            <h3 class="font-bold text-lg mb-2 line-clamp-2">
              {article.title}
            </h3>
            <p class="text-sm text-text-muted mb-4 line-clamp-3">
              {article.excerpt}
            </p>
            <Button variant="link" size="sm" href={`/news/kbo/${article.slug}/`}>
              Lire la suite →
            </Button>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Info KBO -->
  <section class="section">
    <div class="container mx-auto">
      <Card variant="bordered" padding="lg" class="max-w-3xl mx-auto">
        <h3 class="text-xl font-bold mb-4">📖 À propos de la KBO League</h3>
        <p class="text-text-secondary mb-4">
          La <strong>Korean Baseball Organization (KBO)</strong> est la ligue professionnelle de baseball de Corée du Sud.
          Créée en 1982, elle compte actuellement <strong>10 équipes</strong> réparties dans tout le pays.
        </p>
        <p class="text-text-secondary mb-4">
          La saison régulière se déroule de mars à octobre, suivie des playoffs et de la Korean Series qui détermine le champion.
          Le baseball est l'un des sports les plus populaires en Corée du Sud, avec une moyenne de plus de 8 000 spectateurs par match.
        </p>
        <div class="flex gap-3 mt-6">
          <Button variant="ghost" size="sm" href="/histoire/kbo/korean-series/">
            Histoire de la Korean Series
          </Button>
          <Button variant="ghost" size="sm" href="/kbo/equipes/">
            Découvrir les 10 équipes
          </Button>
        </div>
      </Card>
    </div>
  </section>
</BaseLayout>
