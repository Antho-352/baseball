---
/**
 * BaseLayout - Layout de base pour toutes les pages
 *
 * Props:
 * - title: Titre de la page
 * - description: Meta description
 * - ogImage?: Image Open Graph
 * - showNav?: Afficher la navigation (défaut: true)
 * - showFooter?: Afficher le footer (défaut: true)
 */

import NavBar from '@components/ui/NavBar.astro';
import Footer from '@components/ui/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  showNav?: boolean;
  showFooter?: boolean;
}

const {
  title,
  description,
  ogImage,
  showNav = true,
  showFooter = true,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const defaultOgImage = new URL('/og-default.jpg', Astro.site);
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage || defaultOgImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage || defaultOgImage} />

    <!-- Dark mode: éviter le flash -->
    <script is:inline>
      // Exécuté AVANT le render pour éviter le flash
      const theme = localStorage.getItem('theme') ||
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.dataset.theme = theme;
    </script>

    <!-- Preload fonts (si hébergées localement) -->
    <!-- <link rel="preload" href="/fonts/inter-var.woff2" as="font" type="font/woff2" crossorigin> -->

    <!-- Global CSS -->
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body>
    <!-- Navigation -->
    {showNav && <NavBar currentPath={Astro.url.pathname} />}

    <!-- Contenu de la page -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    {showFooter && <Footer />}
  </body>
</html>

<style>
  /* Styles spécifiques au layout (si nécessaire) */
  html {
    scroll-behavior: smooth;
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
  }
</style>
